{
  "name": "aria",
  "version": "2026.3.4",
  "description": "Esperta Aria — Local-first agent platform",
  "type": "module",
  "main": "packages/cli/src/index.ts",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "aria": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run packages/cli/src/index.ts",
    "build": "bun scripts/copy-docs.ts && bun run scripts/embed-skills.ts && bun build packages/cli/src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "lint": "eslint packages/ tests/ scripts/",
    "typecheck": "tsc --noEmit",
    "version:bump": "bun run scripts/version.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@chat-adapter/discord": "^4.24.0",
    "@chat-adapter/gchat": "^4.24.0",
    "@chat-adapter/github": "^4.24.0",
    "@chat-adapter/linear": "^4.24.0",
    "@chat-adapter/slack": "^4.24.0",
    "@chat-adapter/state-memory": "^4.24.0",
    "@chat-adapter/teams": "^4.24.0",
    "@chat-adapter/telegram": "^4.24.0",
    "@mariozechner/pi-ai": "^0.66.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "chat": "^4.24.0",
    "ink": "^7.0.0",
    "node-html-markdown": "^2.0.0",
    "react": "^19.2.5",
    "superjson": "^2.2.6",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "bun-types": "^1.3.11",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "react-devtools-core": "^7.0.1",
    "typescript": "^6.0.2"
  }
}
